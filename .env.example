# Public browser-safe Supabase values. Required for connected local/dev/prod usage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL used for auth redirects and links in Discord alerts.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only optional values. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
DISCORD_WEBHOOK_URL=
